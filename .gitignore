# GeoDisha — root .gitignore

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.venv/
**/.venv/
*.egg-info/
dist/
*.log

# Flutter / Dart
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/pubspec.lock
mobile/.idea/
mobile/**/*.g.dart
mobile/**/*.freezed.dart

# Environment files — never commit secrets
.env
**/.env
*.env.local

# Terraform state
**/.terraform/
*.tfstate
*.tfstate.backup

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test artifacts
coverage/
*.lcov

# Build artifacts
build/
dist/
*.tar.gz
*.zip
