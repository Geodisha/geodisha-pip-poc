FROM nginx:alpine

# Copy built Flutter web app
COPY build/web /usr/share/nginx/html

# Nginx config for Flutter SPA (handle deep links)
RUN printf 'server {\n\
    listen 8080;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 8080
